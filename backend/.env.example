# Supabase (https://supabase.com → Project Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Google AI Studio (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Upstash Redis (https://upstash.com → Create database → REST URL is fine, or use the redis:// URL)
REDIS_URL=redis://default:password@host:6379

# CORS origins (comma-separated). Add the Vercel URL of your frontend.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://optisleep-app.vercel.app
